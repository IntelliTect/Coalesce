{
  "name": "coalesce",
  "version": "0.1.0-local",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r --filter=./src/* run build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "coalesce": "pnpm -C playground/Coalesce.Web.Vue3 coalesce",
    "doc": "pnpm -C docs dev",
    "play": "dotnet run --project playground/Coalesce.Web.Vue3",
    "template": "pwsh templates/Coalesce.Vue.Template/TestLocal.ps1",
    "template:run": "dotnet run --project templates/Coalesce.Vue.Template/content/Coalesce.Starter.Vue.AppHost",
    "test": "pnpm -r --filter=./src/* run test run",
    "check": "pnpm -r --filter=./src/* run \"/build|test/\""
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "1.6.21",
    "@vue/eslint-config-typescript": "14.9.0",
    "@vue/test-utils": "^2.4.11",
    "cspell": "10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0",
    "typescript": "6.0.3",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6"
  }
}
