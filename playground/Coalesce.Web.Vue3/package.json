{
  "name": "coalesce-web-vue3",
  "version": "0.1.0-local",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "vite preview",
    "build": "vite build && vue-tsc --noEmit",
    "lint": "eslint src",
    "coverage": "vitest run --coverage",
    "dev": "vite",
    "lint:fix": "eslint src --fix",
    "test": "vitest",
    "coalesce": "dotnet run --project ../../src/IntelliTect.Coalesce.DotnetTool --framework net10.0 -- ../../coalesce-vue3.json"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-mono": "^5.2.8",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@mdi/font": "7.1.96",
    "coalesce-vue": "workspace:*",
    "coalesce-vue-vuetify3": "workspace:*",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4",
    "vuetify": "4.0.5"
  },
  "devDependencies": {
    "vite-plugin-vuetify": "^2.1.3"
  }
}
