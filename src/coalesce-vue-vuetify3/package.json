{
  "name": "coalesce-vue-vuetify3",
  "version": "0.1.0-local",
  "description": "Vuetify 3/Vuetify 4 components for IntelliTect's Coalesce framework.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IntelliTect/Coalesce.git"
  },
  "author": "IntelliTect",
  "license": "Apache-2.0",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "styles": "./dist/coalesce-vue-vuetify.css",
  "types": "./dist/index.d.ts",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "style": "./dist/coalesce-vue-vuetify.css",
      "default": "./dist/index.js"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "default": "./dist/build.js"
    },
    "./*": "./dist/*",
    "./styles": "./dist/coalesce-vue-vuetify.css",
    "./styles.css": "./dist/coalesce-vue-vuetify.css"
  },
  "typesVersions": {
    "*": {
      "*": [
        "*",
        "dist/*"
      ]
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm --filter=coalesce-vue run build",
    "build": "vite build && vue-tsc --noEmit && vue-tsc -p ./tsconfig.build-types.json && pnpm buildts",
    "buildts": "tsc -p ./tsconfig.build-utils.json",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "peerDependencies": {
    "coalesce-vue": "workspace:*",
    "date-fns": "^3.0.0 || ^4.0.0",
    "date-fns-tz": "^3.0.0",
    "vue": "^3.5.4",
    "vuetify": "^3.7.1 || ^4.0.0"
  },
  "optionalDependencies": {
    "vue-router": "^4.4.1 || ^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "axe-core": "^4.11.4",
    "axios": "^1.18.0",
    "coalesce-vue": "workspace:*",
    "vue-component-type-helpers": "^2.2.12",
    "vue-router": "^4.4.1 || ^5.0.0",
    "vuetify": "4.0.5"
  }
}
