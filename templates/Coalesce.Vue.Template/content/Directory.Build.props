<Project>
  <PropertyGroup>
    <LangVersion>14.0</LangVersion>
    <ImplicitUsings>true</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UserSecretsId>427b7da5-dfe1-43cc-b172-40fe2d2fa505</UserSecretsId>

    <AccelerateBuildsInVisualStudio>true</AccelerateBuildsInVisualStudio>

    <CoalesceVersion>6.5.0-beta.20260504.1</CoalesceVersion>
    <!-- Disable Source Link attribute in Debug to avoid hot reload issues.
         In Release, the source revision is included for app update detection. -->
    <IncludeSourceRevisionInInformationalVersion Condition="'$(Configuration)' == 'Debug'">false</IncludeSourceRevisionInInformationalVersion>

    <!--#if
    (KeepTemplateOnly) -->
    <DefineConstants>$(DefineConstants);KeepTemplateOnly;AppInsights;OpenAPI;AuditLogs;TrackingBase;ExampleModel</DefineConstants>
    <DefineConstants>$(DefineConstants);Identity;Passkeys;UserPictures;MicrosoftAuth;GoogleAuth;Passwords;OtherOAuth</DefineConstants>
    <DefineConstants>$(DefineConstants);EmailAzure;EmailSendGrid;Hangfire;AIChat;KeyVault;BlobStorage;AzureTerraform</DefineConstants>
    <DefineConstants>$(DefineConstants);Tenancy;TenantPerHostname;TenantCreateSelf;TenantCreateExternal;TenantCreateAdmin;TenantMemberInvites</DefineConstants>
    <!--#endif -->
  </PropertyGroup>
</Project>